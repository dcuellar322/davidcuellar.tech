---
import { ArrowDown, ArrowUpRight, MapPin, Sparkles } from "lucide-react";
import { FaGithub, FaLinkedinIn, FaXTwitter } from "react-icons/fa6";
import { profile } from "../data/profile";
import { getExperienceYears } from "../utils/dates";
import ThreeScene from "./ThreeScene";

const experienceYears = getExperienceYears();
---

<section class="hero section" id="top" aria-labelledby="hero-title">
  <div class="container hero-grid">
    <div class="hero-copy" data-reveal>
      <div class="eyebrow-row">
        <span class="orb" aria-hidden="true"></span>
        {profile.eyebrow}
      </div>
      <h1 id="hero-title">{profile.headline}</h1>
      <p class="hero-positioning">{profile.positioning}</p>
      <p class="hero-subcopy">{profile.heroSubheadline}</p>
      <div class="hero-meta" aria-label="Profile context">
        <span><MapPin aria-hidden="true" /> {profile.location}</span>
        <span>
          <Sparkles aria-hidden="true" />
          <span><span data-experience-years>{experienceYears}</span>+ years across product, platform, data, and operations</span>
        </span>
      </div>
      <div class="hero-actions">
        <a class="button primary" href="#build-log">
          Explore the build log
          <ArrowDown aria-hidden="true" />
        </a>
        <a class="button" href="#projects">
          View projects
          <ArrowUpRight aria-hidden="true" />
        </a>
        <a class="button ghost" href={profile.social.linkedin} target="_blank" rel="noreferrer">
          Connect on LinkedIn
          <FaLinkedinIn aria-hidden="true" />
        </a>
      </div>
      <div class="social-strip" aria-label="Social links">
        <a href={profile.social.github} target="_blank" rel="noreferrer"><FaGithub aria-hidden="true" /> GitHub</a>
        <a href={profile.social.x} target="_blank" rel="noreferrer"><FaXTwitter aria-hidden="true" /> X</a>
      </div>
    </div>

    <div class="hero-visual" data-reveal>
      <div class="scene-frame" aria-hidden="true">
        <ThreeScene client:load />
        <div class="scene-hud scene-hud-top">
          <span>DavidOS</span>
          <strong>Systems in Motion</strong>
        </div>
        <div class="scene-hud scene-hud-bottom">
          <span>Nodes</span>
          <strong>projects · roles · skills</strong>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    min-height: calc(100vh - 70px);
    display: grid;
    align-items: center;
    padding-top: 72px;
  }

  .hero-grid {
    display: grid;
    grid-template-columns: minmax(0, 0.88fr) minmax(420px, 1fr);
    gap: 42px;
    align-items: center;
  }

  .hero-copy {
    position: relative;
    z-index: 2;
  }

  .hero h1 {
    margin: 1.15rem 0 1rem;
    max-width: 780px;
    font-size: clamp(3.2rem, 8.6vw, 7.25rem);
    line-height: 0.88;
    letter-spacing: 0;
  }

  .hero-positioning {
    max-width: 720px;
    margin: 0;
    color: var(--text);
    font-size: clamp(1.14rem, 2vw, 1.42rem);
    font-weight: 650;
    line-height: 1.42;
  }

  .hero-subcopy {
    max-width: 700px;
    margin: 1rem 0 0;
    color: var(--muted);
    font-size: 1rem;
  }

  .hero-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.7rem;
    margin-top: 1.45rem;
  }

  .hero-meta span,
  .social-strip a {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    color: var(--muted);
    font-size: 0.82rem;
    font-weight: 750;
  }

  .hero-meta svg,
  .social-strip svg {
    width: 1rem;
    height: 1rem;
    color: var(--cyan);
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.78rem;
    margin-top: 2rem;
  }

  .social-strip {
    display: flex;
    gap: 1rem;
    margin-top: 1.3rem;
  }

  .social-strip a {
    transition: color 180ms var(--ease-out);
  }

  .social-strip a:hover {
    color: var(--text);
  }

  .hero-visual {
    min-width: 0;
  }

  .scene-frame {
    position: relative;
    min-height: 590px;
    overflow: hidden;
    border: 1px solid rgba(255, 255, 255, 0.13);
    border-radius: var(--radius);
    background:
      radial-gradient(circle at 50% 42%, rgba(103, 232, 249, 0.12), transparent 32%),
      linear-gradient(145deg, rgba(255, 255, 255, 0.09), rgba(255, 255, 255, 0.025));
    box-shadow: var(--shadow);
  }

  .scene-frame :global(.three-scene-canvas) {
    position: absolute !important;
    inset: 0;
    z-index: 0;
    width: 100% !important;
    height: 100% !important;
  }

  .scene-frame :global(.three-scene-canvas canvas) {
    width: 100% !important;
    height: 100% !important;
  }

  .scene-frame::before,
  .scene-frame::after {
    position: absolute;
    inset: 18px;
    z-index: 1;
    pointer-events: none;
    content: "";
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: var(--radius-sm);
  }

  .scene-frame::after {
    inset: auto 18px 18px;
    height: 34%;
    border-top: 1px solid rgba(103, 232, 249, 0.18);
    border-right: 0;
    border-bottom: 0;
    border-left: 0;
    border-radius: 0;
    background: linear-gradient(180deg, transparent, rgba(5, 7, 13, 0.48));
  }

  .scene-hud {
    position: absolute;
    z-index: 4;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    border: 1px solid rgba(255, 255, 255, 0.12);
    border-radius: var(--radius-sm);
    background: rgba(5, 7, 13, 0.58);
    padding: 0.68rem 0.78rem;
    backdrop-filter: blur(14px);
  }

  .scene-hud-top {
    top: 30px;
    right: 30px;
    left: 30px;
  }

  .scene-hud-bottom {
    right: 30px;
    bottom: 30px;
    left: 30px;
  }

  .scene-hud span {
    color: var(--muted-2);
    font-family: var(--font-mono);
    font-size: 0.7rem;
    text-transform: uppercase;
  }

  .scene-hud strong {
    color: var(--text);
    font-size: 0.78rem;
  }

  @media (max-width: 980px) {
    .hero {
      min-height: 0;
    }

    .hero-grid {
      grid-template-columns: 1fr;
    }

    .scene-frame {
      min-height: 460px;
    }
  }

  @media (max-width: 620px) {
    .hero {
      padding-top: 48px;
    }

    .hero h1 {
      font-size: clamp(3rem, 18vw, 4.85rem);
    }

    .hero-actions {
      display: grid;
    }

    .scene-frame {
      min-height: 390px;
    }

    .scene-hud {
      right: 16px;
      left: 16px;
    }

    .scene-hud-top {
      top: 16px;
    }

    .scene-hud-bottom {
      bottom: 16px;
    }
  }
</style>
