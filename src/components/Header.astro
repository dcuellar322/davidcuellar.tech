---
import { FaGithub, FaLinkedinIn, FaXTwitter } from "react-icons/fa6";
import { profile } from "../data/profile";

const navItems = [
  { label: "Work", href: "#principles" },
  { label: "Projects", href: "#projects" },
  { label: "Resume", href: "#resume" },
  { label: "Stack", href: "#skills" },
  { label: "Contact", href: "#contact" },
];
---

<header class="site-header" data-header>
  <a class="brand" href="#top" aria-label="David Cuellar home">
    <span class="brand-mark" aria-hidden="true">DC</span>
    <span>
      <strong>{profile.name}</strong>
      <small>{profile.role}</small>
    </span>
  </a>

  <nav class="site-nav" aria-label="Primary navigation">
    {navItems.map((item) => <a href={item.href}>{item.label}</a>)}
  </nav>

  <div class="header-actions" aria-label="Social and command actions">
    <a class="icon-link" href={profile.social.linkedin} aria-label="LinkedIn" target="_blank" rel="noreferrer">
      <FaLinkedinIn aria-hidden="true" />
    </a>
    <a class="icon-link" href={profile.social.github} aria-label="GitHub" target="_blank" rel="noreferrer">
      <FaGithub aria-hidden="true" />
    </a>
    <a class="icon-link" href={profile.social.x} aria-label="X" target="_blank" rel="noreferrer">
      <FaXTwitter aria-hidden="true" />
    </a>
    <button class="command-trigger" type="button" data-command-open aria-label="Open command palette">
      <kbd><span class="command-symbol">⌘</span><span>K</span></kbd>
    </button>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 40;
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    gap: 1rem;
    align-items: center;
    width: min(1220px, calc(100vw - 32px));
    margin: 12px auto 0;
    border: 1px solid rgba(255, 255, 255, 0.11);
    border-radius: var(--radius);
    background: rgba(5, 7, 13, 0.72);
    padding: 0.7rem;
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.28);
    backdrop-filter: blur(18px);
  }

  .brand {
    display: inline-flex;
    align-items: center;
    gap: 0.72rem;
    min-width: 0;
  }

  .brand-mark {
    display: grid;
    width: 40px;
    height: 40px;
    place-items: center;
    border: 1px solid rgba(103, 232, 249, 0.45);
    border-radius: var(--radius-sm);
    background: linear-gradient(135deg, rgba(103, 232, 249, 0.2), rgba(167, 139, 250, 0.12));
    color: var(--cyan);
    font-size: 0.82rem;
    font-weight: 900;
  }

  .brand strong,
  .brand small {
    display: block;
  }

  .brand strong {
    font-size: 0.92rem;
    line-height: 1.1;
  }

  .brand small {
    margin-top: 0.1rem;
    color: var(--muted-2);
    font-size: 0.72rem;
    font-weight: 750;
  }

  .site-nav {
    display: flex;
    gap: 0.28rem;
    align-items: center;
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: var(--radius-sm);
    background: rgba(255, 255, 255, 0.035);
    padding: 0.24rem;
  }

  .site-nav a {
    border-radius: 5px;
    padding: 0.54rem 0.68rem;
    color: var(--muted);
    font-size: 0.78rem;
    font-weight: 800;
    transition:
      color 180ms var(--ease-out),
      background 180ms var(--ease-out);
  }

  .site-nav a:hover,
  .site-nav a[data-active="true"] {
    background: rgba(255, 255, 255, 0.08);
    color: var(--text);
  }

  .header-actions {
    display: flex;
    justify-content: flex-end;
    gap: 0.42rem;
  }

  .icon-link,
  .command-trigger {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    height: 40px;
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: var(--radius-sm);
    background: rgba(255, 255, 255, 0.045);
    color: var(--muted);
    transition:
      transform 180ms var(--ease-out),
      color 180ms var(--ease-out),
      border-color 180ms var(--ease-out),
      background 180ms var(--ease-out);
  }

  .icon-link {
    width: 40px;
  }

  .icon-link:hover,
  .command-trigger:hover {
    transform: translateY(-1px);
    border-color: rgba(103, 232, 249, 0.35);
    background: rgba(103, 232, 249, 0.08);
    color: var(--text);
  }

  .icon-link svg {
    width: 1rem;
    height: 1rem;
  }

  .command-trigger {
    min-width: 68px;
    padding: 0 0.78rem;
    cursor: pointer;
  }

  .command-trigger kbd {
    display: inline-flex;
    align-items: center;
    gap: 0.42rem;
    color: var(--muted);
    font-family: var(--font-mono);
    font-size: 0.92rem;
    font-weight: 900;
    letter-spacing: 0.02em;
  }

  .command-trigger .command-symbol {
    color: var(--cyan);
    font-size: 0.86rem;
    text-shadow: 0 0 16px rgba(103, 232, 249, 0.45);
  }

  @media (max-width: 940px) {
    .site-header {
      grid-template-columns: 1fr auto;
    }

    .site-nav {
      display: none;
    }
  }

  @media (max-width: 540px) {
    .site-header {
      width: min(100vw - 20px, 1220px);
      margin-top: 8px;
      padding: 0.5rem;
    }

    .brand small,
    .icon-link:nth-child(2),
    .icon-link:nth-child(3) {
      display: none;
    }
  }
</style>
