---
import { MapPin } from "lucide-react";
import { FaGithub, FaLinkedinIn, FaXTwitter } from "react-icons/fa6";
import { profile } from "../data/profile";

const currentYear = new Date().getFullYear();
---

<footer class="footer section tight" id="contact">
  <div class="container footer-grid">
    <div>
      <p class="kicker">Contact</p>
      <h2>Want to compare notes on engineering systems, product ideas, or family workflow apps?</h2>
      <p class="footer-copy">Husband, father, weekend golfer, and builder of useful systems.</p>
    </div>
    <div class="footer-actions glass">
      <a href={profile.social.linkedin} target="_blank" rel="noreferrer">
        <FaLinkedinIn aria-hidden="true" />
        LinkedIn
      </a>
      <a href={profile.social.github} target="_blank" rel="noreferrer">
        <FaGithub aria-hidden="true" />
        GitHub
      </a>
      <a href={profile.social.x} target="_blank" rel="noreferrer">
        <FaXTwitter aria-hidden="true" />
        X
      </a>
      <span>
        <MapPin aria-hidden="true" />
        {profile.location}
      </span>
    </div>
  </div>
  <div class="container footer-verse" aria-label="Favorite scripture">
    <p>"Do justice, love kindness, and walk humbly."</p>
    <cite>Micah 6:8</cite>
  </div>
  <div class="container footer-bottom">
    <span>DavidOS: Systems in Motion</span>
    <span>&copy; <span data-current-year>{currentYear}</span> {profile.name}</span>
  </div>
</footer>

<style>
  .footer {
    border-top: 1px solid rgba(255, 255, 255, 0.08);
  }

  .footer-grid {
    display: grid;
    grid-template-columns: minmax(0, 0.82fr) minmax(280px, 0.42fr);
    gap: 2rem;
    align-items: start;
  }

  h2 {
    margin: 0;
    max-width: 850px;
    font-size: clamp(2rem, 5vw, 4.55rem);
    line-height: 0.96;
    letter-spacing: 0;
  }

  .footer-copy {
    max-width: 620px;
    margin: 1rem 0 0;
    color: var(--muted);
  }

  .footer-verse {
    position: relative;
    display: grid;
    justify-items: center;
    gap: 0.45rem;
    margin-top: 3.4rem;
    padding: 2rem 1rem 2.2rem;
    text-align: center;
  }

  .footer-verse::before,
  .footer-verse::after {
    width: min(420px, 86%);
    height: 1px;
    content: "";
    background: linear-gradient(90deg, transparent, rgba(103, 232, 249, 0.45), transparent);
  }

  .footer-verse p {
    max-width: 840px;
    margin: 0;
    color: var(--text);
    font-family: Georgia, "Times New Roman", serif;
    font-size: clamp(1.85rem, 4.8vw, 4.2rem);
    font-style: italic;
    font-weight: 500;
    letter-spacing: 0;
    line-height: 1.05;
    text-wrap: balance;
  }

  .footer-verse cite {
    color: var(--cyan);
    font-family: var(--font-mono);
    font-size: 0.76rem;
    font-style: normal;
    font-weight: 850;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }

  .footer-actions {
    display: grid;
    gap: 0.58rem;
    padding: 1rem;
  }

  .footer-actions a,
  .footer-actions span {
    display: flex;
    align-items: center;
    gap: 0.65rem;
    border: 1px solid rgba(255, 255, 255, 0.09);
    border-radius: var(--radius-sm);
    background: rgba(255, 255, 255, 0.035);
    padding: 0.85rem;
    color: var(--muted);
    font-weight: 800;
  }

  .footer-actions a:hover {
    color: var(--text);
    border-color: rgba(103, 232, 249, 0.35);
  }

  .footer-actions svg {
    width: 1rem;
    height: 1rem;
    color: var(--cyan);
  }

  .footer-bottom {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    margin-top: 0;
    border-top: 1px solid rgba(255, 255, 255, 0.08);
    padding-top: 1rem;
    color: var(--muted-2);
    font-size: 0.8rem;
    font-weight: 750;
  }

  @media (max-width: 760px) {
    .footer-grid,
    .footer-bottom {
      grid-template-columns: 1fr;
      flex-direction: column;
    }
  }
</style>
