---
interface Props {
  id?: string;
  kicker: string;
  title: string;
  description?: string;
  descriptionHtml?: string;
}

const { id, kicker, title, description, descriptionHtml } = Astro.props;
---

<div class="section-heading" data-reveal>
  <div>
    <p class="kicker">{kicker}</p>
    <h2 id={id}>{title}</h2>
  </div>
  {descriptionHtml ? <p set:html={descriptionHtml} /> : <p>{description}</p>}
</div>
